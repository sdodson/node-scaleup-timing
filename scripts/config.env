# Boot Image Age Study — shared configuration
# Source this file from all study scripts:
#   source "$(dirname "$0")/config.env"

STUDY_NAME="boot-image-study"
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA_DIR="${REPO_DIR}/data/${STUDY_NAME}"
REPORTS_DIR="${REPO_DIR}/reports"

# Cluster parameters (KUBECONFIG must be set externally)
CLUSTER_VERSION="4.18.24"
REGION="us-east-2"
INSTANCE_TYPE="m6i.xlarge"

# Zone mapping: AWS zone letter -> numeric suffix for artifact naming
ZONE_LETTERS=("a" "b" "c")
ZONE_NUMBERS=("1" "2" "3")

# Study parameters
ROUNDS=5
WAIT_TIMEOUT=900    # 15 min max wait per node
POLL_INTERVAL=20    # seconds between readiness checks
COOLDOWN=30         # seconds between rounds

# Boot image versions to test (native first, then progressively older)
BOOT_VERSIONS=(
  "4.18.24"
  "4.18.0"
  "4.17.35"
  "4.16.41"
  "4.15.51"
  "4.14.38"
  "4.13.51"
  "4.12.40"
  "4.11.35"
  "4.10.20"
)

# AMI file (populated by lookup-ami.sh)
AMI_FILE="${DATA_DIR}/amis.env"

# Helper: convert version string to env var name (4.18.24 -> AMI_4_18_24)
version_to_var() {
  echo "AMI_$(echo "$1" | tr '.' '_')"
}

# Helper: look up AMI for a version from amis.env
get_ami() {
  local var
  var=$(version_to_var "$1")
  if [ -f "$AMI_FILE" ]; then
    source "$AMI_FILE"
    echo "${!var:-}"
  fi
}

# Helper: convert zone letter to zone number (a->1, b->2, c->3)
zone_to_num() {
  case "$1" in
    a) echo 1 ;; b) echo 2 ;; c) echo 3 ;;
    *) echo "$1" ;;
  esac
}

# Helper: build the artifact suffix
make_suffix() {
  local boot_version="$1" round="$2" zone_letter="$3"
  echo "${boot_version}-m6i-r${round}-z$(zone_to_num "$zone_letter")"
}

# Validate KUBECONFIG is set
check_kubeconfig() {
  if [ -z "${KUBECONFIG:-}" ]; then
    echo "ERROR: KUBECONFIG is not set. Export it before running this script." >&2
    exit 1
  fi
  if [ ! -f "$KUBECONFIG" ]; then
    echo "ERROR: KUBECONFIG file not found: $KUBECONFIG" >&2
    exit 1
  fi
}
