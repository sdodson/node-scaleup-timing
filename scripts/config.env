# Universal scale-up study configuration
# Source this file from all study scripts:
#   source "$(dirname "$0")/config.env"
#
# Required env vars (set by caller):
#   KUBECONFIG   — path to kubeconfig file
#   STUDY_NAME   — study identifier, used for DATA_DIR=data/${STUDY_NAME}

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DATA_DIR="${REPO_DIR}/data/${STUDY_NAME:?STUDY_NAME must be set}"

# Overridable defaults
WAIT_TIMEOUT="${WAIT_TIMEOUT:-900}"
POLL_INTERVAL="${POLL_INTERVAL:-20}"
COOLDOWN="${COOLDOWN:-30}"
MACHINESET_PATTERN="${MACHINESET_PATTERN:-worker-test}"

# Validate KUBECONFIG is set and exists
check_kubeconfig() {
  if [ -z "${KUBECONFIG:-}" ]; then
    echo "ERROR: KUBECONFIG is not set. Export it before running this script." >&2
    exit 1
  fi
  if [ ! -f "$KUBECONFIG" ]; then
    echo "ERROR: KUBECONFIG file not found: $KUBECONFIG" >&2
    exit 1
  fi
}

# Auto-detect MAPI vs CAPI namespace. Sets MACHINE_NS.
# Skip detection if MACHINE_NS is already set (allows override).
detect_machine_namespace() {
  if [ -n "${MACHINE_NS:-}" ]; then
    return
  fi
  if oc get machinesets -n openshift-machine-api --no-headers 2>/dev/null | grep -q .; then
    MACHINE_NS="openshift-machine-api"
  elif oc get machinesets -n openshift-cluster-api --no-headers 2>/dev/null | grep -q .; then
    MACHINE_NS="openshift-cluster-api"
  else
    echo "ERROR: No MachineSets found in openshift-machine-api or openshift-cluster-api" >&2
    exit 1
  fi
  export MACHINE_NS
}

# Find test MachineSets matching MACHINESET_PATTERN. Populates TEST_MACHINESETS array.
discover_test_machinesets() {
  TEST_MACHINESETS=()
  while IFS= read -r name; do
    [ -n "$name" ] && TEST_MACHINESETS+=("$name")
  done < <(oc get machinesets -n "$MACHINE_NS" --no-headers \
    -o custom-columns=NAME:.metadata.name 2>/dev/null \
    | grep "$MACHINESET_PATTERN" | sort)
  if [ ${#TEST_MACHINESETS[@]} -eq 0 ]; then
    echo "ERROR: No MachineSets matching '${MACHINESET_PATTERN}' in ${MACHINE_NS}" >&2
    exit 1
  fi
  export TEST_MACHINESETS
}

# Extract zone ID from MachineSet name (last segment after final hyphen).
# e.g. "ci-ln-xxx-worker-test-1a" -> "1a"
ms_to_zone_id() {
  echo "${1##*-}"
}
